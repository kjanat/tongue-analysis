		"fmt": "dprint fmt",
		"typecheck": "tsgo --noEmit"
	},
	"repository": "kjanat/tongue-analysis",
	"dependencies": {
		"@mediapipe/tasks-vision": "^0.10.32",
		"react": "^19.2.4",
