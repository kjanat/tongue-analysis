		"hex-to-oklch": "^3.2.0",
		"vite-robots-txt": "^1.0.0",
		"vite-svg-to-ico": "^2.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260307.1",
		"@vitejs/plugin-react": "^5.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"dprint": "^0.52.0",
		"eslint": "^10.0.3",
		"eslint-plugin-react-dom": "^2.13.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-react-x": "^2.13.0",
		"gl": "^8.1.6",
		"globals": "^17.4.0",
		"sharp": "^0.34.5",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^8.0.0-beta.16"
	},
	"overrides": {
		"vite": "^8.0.0-beta.16"
	},
	"packageManager": "bun@1.3.10",
	"volta": {
		"node": "24.13.0"
	}
